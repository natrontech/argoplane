{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "npx pagefind --site build --output-path build/pagefind",
		"search:index": "vite build && npx pagefind --site build --output-path static/pagefind",
		"preview": "npx sirv build --single --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"mdsvex": "^0.12.7",
		"pagefind": "^1.5.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^4.0.2",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.9"
	},
	"dependencies": {
		"lucide-svelte": "^1.0.1"
	}
}
